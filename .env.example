# OpenWeatherMap API key (required). Get one at https://openweathermap.org/api
WEATHER_API_KEY=

# Flask session secret (optional). Falls back to a dev-only default if unset.
SESSION_SECRET=

# Push notifications (optional). If unset, keys/token are auto-generated and
# persisted under instance/ for local dev - but on a host with an ephemeral
# filesystem (e.g. Render's free tier) that means every redeploy silently
# invalidates all existing subscriptions. Set these for any real deployment;
# see README.md for how to generate VAPID_PUBLIC_KEY/VAPID_PRIVATE_KEY once.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_CONTACT_EMAIL=
# Shared secret for the external scheduler that hits /api/push/check
PUSH_CHECK_TOKEN=
